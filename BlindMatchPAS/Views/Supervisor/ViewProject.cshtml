@model BlindMatchPAS.Models.Project
@{
    ViewData["Title"] = "View Project";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="fw-bold">
            <i class="bi bi-file-earmark-text text-primary"></i> Project Details
        </h2>
        <div class="alert alert-warning border-0 shadow-sm">
            <i class="bi bi-eye-slash"></i>
            <strong>Blind Review Mode:</strong>
            Student identity is completely hidden until you confirm a match.
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0 fw-bold">@Model.Title</h4>
                <span class="badge bg-primary rounded-pill">
                    @Model.ResearchArea
                </span>
            </div>
        </div>
        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="p-3 bg-light rounded">
                        <h6 class="fw-bold text-muted mb-2">
                            <i class="bi bi-stack"></i> Technical Stack
                        </h6>
                        <p class="mb-0">@Model.TechnicalStack</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 bg-light rounded">
                        <h6 class="fw-bold text-muted mb-2">
                            <i class="bi bi-diagram-3"></i> Status
                        </h6>
                        <span class="badge bg-secondary">@Model.Status</span>
                    </div>
                </div>
                <div class="col-12">
                    <div class="p-3 bg-light rounded">
                        <h6 class="fw-bold text-muted mb-2">
                            <i class="bi bi-file-text"></i> Abstract
                        </h6>
                        <p class="mb-0 lh-lg">@Model.Abstract</p>
                    </div>
                </div>
                <div class="col-12">
                    <div class="p-3 border rounded border-warning">
                        <h6 class="fw-bold text-warning mb-2">
                            <i class="bi bi-lock"></i> Student Identity
                        </h6>
                        <p class="mb-0 text-muted">
                            🔒 Hidden — Will be revealed after match confirmation
                        </p>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-white border-0 pb-4 px-4">
            <form asp-action="ExpressInterest" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-success me-2"
                    onclick="return confirm('Express interest in this project?')">
                    <i class="bi bi-hand-thumbs-up"></i> Express Interest
                </button>
            </form>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Browse
            </a>
        </div>
    </div>
</div>