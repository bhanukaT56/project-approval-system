@model IEnumerable<BlindMatchPAS.Models.Project>
@{
    ViewData["Title"] = "Browse Projects";
}

<h2>Browse Anonymous Project Proposals</h2>
<p class="text-muted">Student identities are hidden until you confirm a match.</p>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form method="get" asp-action="Index" class="mb-3">
    <div class="input-group">
        <select name="area" class="form-select">
            <option value="">-- Filter by Research Area --</option>
            <option value="Artificial Intelligence"
                    selected="@(ViewBag.SelectedArea == "Artificial Intelligence")">
                Artificial Intelligence
            </option>
            <option value="Web Development"
                    selected="@(ViewBag.SelectedArea == "Web Development")">
                Web Development
            </option>
            <option value="Cybersecurity"
                    selected="@(ViewBag.SelectedArea == "Cybersecurity")">
                Cybersecurity
            </option>
            <option value="Cloud Computing"
                    selected="@(ViewBag.SelectedArea == "Cloud Computing")">
                Cloud Computing
            </option>
            <option value="Machine Learning"
                    selected="@(ViewBag.SelectedArea == "Machine Learning")">
                Machine Learning
            </option>
            <option value="Data Science"
                    selected="@(ViewBag.SelectedArea == "Data Science")">
                Data Science
            </option>
            <option value="Mobile Development"
                    selected="@(ViewBag.SelectedArea == "Mobile Development")">
                Mobile Development
            </option>
        </select>
        <button type="submit" class="btn btn-primary">Filter</button>
        <a asp-action="Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

@if (!Model.Any())
{
    <p>No projects available for your selected area.</p>
}
else
{
    <div class="row">
        @foreach (var project in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@project.Title</h5>
                        <span class="badge bg-primary mb-2">@project.ResearchArea</span>
                        <p class="card-text text-muted">
                            @(project.Abstract.Length > 100
                                ? project.Abstract.Substring(0, 100) + "..."
                                : project.Abstract)
                        </p>
                        <p><strong>Tech Stack:</strong> @project.TechnicalStack</p>
                        <p class="text-warning"><strong>Student: Anonymous 🔒</strong></p>
                    </div>
                    <div class="card-footer">
                        <a asp-action="ViewProject" asp-route-id="@project.Id"
                           class="btn btn-sm btn-info">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<a asp-action="MyInterests" class="btn btn-outline-primary mt-3">
    View My Interests
</a>