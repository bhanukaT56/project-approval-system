@model BlindMatchPAS.Models.Project
@{
    ViewData["Title"] = "Revealed Student Details";
}

<h2>🎉 Match Confirmed!</h2>
<p class="text-muted">The student identity has been revealed.</p>

<div class="card p-4">
    <h4>@Model.Title</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-3">Research Area</dt>
        <dd class="col-sm-9">
            <span class="badge bg-primary">@Model.ResearchArea</span>
        </dd>

        <dt class="col-sm-3">Technical Stack</dt>
        <dd class="col-sm-9">@Model.TechnicalStack</dd>

        <dt class="col-sm-3">Abstract</dt>
        <dd class="col-sm-9">@Model.Abstract</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">
            <span class="badge bg-success">@Model.Status</span>
        </dd>
    </dl>

    <div class="alert alert-success mt-3">
        <h5>👤 Student Details</h5>
        <hr />
        <p><strong>Email:</strong> @ViewBag.StudentEmail</p>
        <p><strong>Student ID:</strong> @ViewBag.StudentId</p>
        <p class="text-muted mt-2">
            Please contact the student via their email to begin collaboration.
        </p>
    </div>
</div>

<a asp-action="MyInterests" class="btn btn-secondary mt-3">
    Back to My Interests
</a>