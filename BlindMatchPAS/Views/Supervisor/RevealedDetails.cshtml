@model BlindMatchPAS.Models.Project
@{
    ViewData["Title"] = "Revealed Student Details";
}

<div class="container mt-4">
    <h2 class="fw-bold">
        <i class="bi bi-check-circle text-success"></i> Match Confirmed!
    </h2>
    <p class="text-muted">The student identity has been revealed.</p>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-dark text-white py-3">
            <h4 class="mb-0 fw-bold">@Model.Title</h4>
        </div>
        <div class="card-body p-4">
            <dl class="row">
                <dt class="col-sm-3">Research Area</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-primary">@Model.ResearchArea</span>
                </dd>
                <dt class="col-sm-3">Technical Stack</dt>
                <dd class="col-sm-9">@Model.TechnicalStack</dd>
                <dt class="col-sm-3">Abstract</dt>
                <dd class="col-sm-9">@Model.Abstract</dd>
            </dl>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-success text-white py-3">
            <h5 class="mb-0">
                <i class="bi bi-person-check"></i> Student Details
            </h5>
        </div>
        <div class="card-body p-4">
            <dl class="row">
                <dt class="col-sm-3">Full Name</dt>
                <dd class="col-sm-9">@ViewBag.StudentFullName</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@ViewBag.StudentEmail</dd>

                <dt class="col-sm-3">Batch</dt>
                <dd class="col-sm-9">@ViewBag.StudentBatch</dd>

                <dt class="col-sm-3">Degree Program</dt>
                <dd class="col-sm-9">@ViewBag.StudentDegreeProgram</dd>
            </dl>
            <div class="alert alert-info mt-3">
                <i class="bi bi-envelope"></i>
                Please contact the student via
                <strong>@ViewBag.StudentEmail</strong>
                to begin collaboration.
            </div>
        </div>
    </div>

    <a asp-action="MyInterests" class="btn btn-secondary mt-4">
        <i class="bi bi-arrow-left"></i> Back to My Interests
    </a>
</div>