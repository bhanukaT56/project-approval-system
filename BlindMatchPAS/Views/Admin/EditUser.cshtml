@model BlindMatchPAS.Models.UserProfile
@{
    ViewData["Title"] = "Edit User";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="fw-bold">
            <i class="bi bi-pencil text-primary"></i> Edit User
        </h2>
        <p class="text-muted">Update user profile details</p>
    </div>

    <div class="card shadow-sm border-0 p-4">
        <div class="alert alert-info mb-4">
            <i class="bi bi-envelope"></i>
            <strong>Email:</strong> @ViewBag.Email
            &nbsp;&nbsp;
            <i class="bi bi-person-badge"></i>
            <strong>Role:</strong> @ViewBag.Role
        </div>

        <form asp-action="EditUser" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="userId" value="@ViewBag.UserId" />

            <h5 class="fw-bold mb-3">
                <i class="bi bi-person"></i> Profile Details
            </h5>

            <div class="mb-3">
                <label class="form-label fw-bold">
                    Full Name <span class="text-danger">*</span>
                </label>
                <input type="text" name="fullName" class="form-control"
                       value="@Model.FullName" required />
            </div>

            @if (ViewBag.Role == "Student")
            {
                <div class="mb-3">
                    <label class="form-label fw-bold">Student ID</label>
                    <input type="text" name="studentNumber" class="form-control"
                           value="@Model.StudentNumber"
                           placeholder="e.g. CB010234" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Batch</label>
                    <input type="text" name="batch" class="form-control"
                           value="@Model.Batch"
                           placeholder="e.g. 2022/2023" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Degree Program</label>
                    <input type="text" name="degreeProgram" class="form-control"
                           value="@Model.DegreeProgram"
                           placeholder="e.g. BSc Computer Science" />
                </div>
            }

            @if (ViewBag.Role == "Supervisor")
            {
                <div class="mb-3">
                    <label class="form-label fw-bold">Supervisor ID</label>
                    <input type="text" name="supervisorNumber" class="form-control"
                           value="@Model.SupervisorNumber"
                           placeholder="e.g. SF001" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Department</label>
                    <input type="text" name="department" class="form-control"
                           value="@Model.Department"
                           placeholder="e.g. Department of Computer Science" />
                </div>
            }

            <div class="mt-4">
                <button type="submit" class="btn btn-primary me-2">
                    <i class="bi bi-save"></i> Save Changes
                </button>
                <a asp-action="Users" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>