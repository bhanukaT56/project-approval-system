@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">
                <i class="bi bi-people text-primary"></i> Manage Users
            </h2>
            <p class="text-muted">Create and manage system users and their roles</p>
        </div>
        <a asp-action="CreateUser" class="btn btn-primary">
            <i class="bi bi-person-plus"></i> Create New User
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="bi bi-funnel"></i> Filter by Role
                    </label>
                    <select class="form-select" id="roleFilter">
                        <option value="">-- All Roles --</option>
                        <option value="Student">Student</option>
                        <option value="Supervisor">Supervisor</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="bi bi-search"></i> Search by Name or Email
                    </label>
                    <input type="text" class="form-control" id="searchFilter"
                           placeholder="Search..." />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100"
                            onclick="clearFilters()">
                        <i class="bi bi-x-circle"></i> Clear
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-people text-muted" style="font-size: 4rem;"></i>
            <h4 class="text-muted mt-3">No users found</h4>
            <a asp-action="CreateUser" class="btn btn-primary mt-2">
                <i class="bi bi-person-plus"></i> Create User
            </a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover mb-0" id="usersTable">
                    <thead>
                        <tr>
                            <th class="ps-4">Full Name</th>
                            <th>Email</th>
                            <th>ID Number</th>
                            <th>Role</th>
                            <th>Batch</th>
                            <th>Degree / Department</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            var roles = ViewBag.UserRoles != null &&
                                ViewBag.UserRoles.ContainsKey(user.Id)
                                ? ViewBag.UserRoles[user.Id] as IList<string>
                                : new List<string>();

                            var profile = ViewBag.UserProfiles != null &&
                                ViewBag.UserProfiles.ContainsKey(user.Id)
                                ? ViewBag.UserProfiles[user.Id] as BlindMatchPAS.Models.UserProfile
                                : null;

                            var roleStr = roles != null && roles.Any()
                                ? string.Join(", ", roles)
                                : "No Role";

                            var idNumber = profile?.StudentNumber
                                ?? profile?.SupervisorNumber
                                ?? "—";

                            <tr class="user-row"
                                data-role="@roleStr"
                                data-name="@(profile?.FullName ?? "")"
                                data-email="@(user.Email ?? "")">
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-primary text-white
                                            d-flex align-items-center justify-content-center me-2"
                                             style="width:35px; height:35px;">
                                            <i class="bi bi-person"></i>
                                        </div>
                                        @(profile?.FullName ?? "N/A")
                                    </div>
                                </td>
                                <td>@user.Email</td>
                                <td>
                                    <span class="badge bg-light text-dark">
                                        @idNumber
                                    </span>
                                </td>
                                <td>
                                    @if (roles != null && roles.Any())
                                    {
                                        foreach (var role in roles)
                                        {
                                            <span class="badge rounded-pill
                                                @(role == "Admin" ? "bg-danger" :
                                                                                                    role == "Supervisor" ? "bg-success" :
                                                                                                    "bg-primary")">
                                                @role
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No Role</span>
                                    }
                                </td>
                                <td>@(profile?.Batch ?? "—")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(profile?.DegreeProgram))
                                    {
                                        @profile.DegreeProgram
                                    }
                                    else if (!string.IsNullOrEmpty(profile?.Department))
                                    {
                                        @profile.Department
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (user.EmailConfirmed)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> Verified
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-exclamation-circle"></i> Unverified
                                        </span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="EditUser" asp-route-id="@user.Id"
                                           class="btn btn-sm btn-outline-primary me-1">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <form asp-action="DeleteUser" method="post"
                                          class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id"
                                               value="@user.Id" />
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Delete this user?')">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <a asp-action="Index" class="btn btn-outline-secondary mt-4">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>
</div>

<script>
    function filterUsers() {
        var roleFilter = document.getElementById('roleFilter').value.toLowerCase();
        var searchFilter = document.getElementById('searchFilter').value.toLowerCase();
        var rows = document.querySelectorAll('.user-row');

        rows.forEach(function (row) {
            var role = row.getAttribute('data-role').toLowerCase();
            var name = row.getAttribute('data-name').toLowerCase();
            var email = row.getAttribute('data-email').toLowerCase();

            var roleMatch = roleFilter === '' || role.includes(roleFilter);
            var searchMatch = searchFilter === '' ||
                name.includes(searchFilter) ||
                email.includes(searchFilter);

            row.style.display = roleMatch && searchMatch ? '' : 'none';
        });
    }

    function clearFilters() {
        document.getElementById('roleFilter').value = '';
        document.getElementById('searchFilter').value = '';
        filterUsers();
    }

    document.getElementById('roleFilter').addEventListener('change', filterUsers);
    document.getElementById('searchFilter').addEventListener('keyup', filterUsers);
</script>