@model IEnumerable<BlindMatchPAS.Models.Project>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2>📊 Admin Dashboard</h2>
<p class="text-muted">Overview of all project allocations.</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary p-3">
            <h5>Total Projects</h5>
            <h2>@Model.Count()</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning p-3">
            <h5>Pending</h5>
            <h2>@Model.Count(p => p.Status == "Pending")</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info p-3">
            <h5>Under Review</h5>
            <h2>@Model.Count(p => p.Status == "Under Review")</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success p-3">
            <h5>Matched</h5>
            <h2>@Model.Count(p => p.Status == "Matched")</h2>
        </div>
    </div>
</div>

<h4>All Projects</h4>

@if (!Model.Any())
{
    <p>No projects in the system yet.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Title</th>
                <th>Research Area</th>
                <th>Status</th>
                <th>Student ID</th>
                <th>Supervisor ID</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var project in Model)
            {
                <tr>
                    <td>@project.Title</td>
                    <td>@project.ResearchArea</td>
                    <td>
                        <span class="badge
                            @(project.Status == "Matched" ? "bg-success" :
                                                            project.Status == "Under Review" ? "bg-warning" :
                                                            "bg-secondary")">
                            @project.Status
                        </span>
                    </td>
                    <td>@project.StudentId</td>
                    <td>@(project.SupervisorId ?? "Not assigned")</td>
                    <td>
                        <a asp-action="Reassign" asp-route-id="@project.Id"
                               class="btn btn-sm btn-warning">
                            🔄 Reassign
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-action="Users" class="btn btn-primary mt-3">
    👥 Manage Users
</a>