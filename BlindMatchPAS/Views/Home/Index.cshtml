@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="px-4 py-5 text-center" style="background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460); color: white; border-radius: 12px; margin-bottom: 2rem;">
    <div class="py-5">
        <h1 class="display-4 fw-bold">
            <i class="bi bi-shield-lock"></i> BlindMatch
        </h1>
        <p class="lead mb-4">
            A fair and unbiased Project Approval System for academic research.
            Student identities are hidden until a supervisor confirms a match.
        </p>
        @if (!User.Identity!.IsAuthenticated)
        {
            
            <a asp-area="Identity" asp-page="/Account/Login"
                   class="btn btn-outline-light btn-lg">
                <i class="bi bi-box-arrow-in-right"></i> Login
            </a>
        }
        else
        {
            @if (User.IsInRole("Student"))
            {
                <a asp-controller="Project" asp-action="Index"
                       class="btn btn-light btn-lg">
                    <i class="bi bi-folder2-open"></i> My Projects
                </a>
            }
            @if (User.IsInRole("Supervisor"))
            {
                <a asp-controller="Supervisor" asp-action="Index"
                       class="btn btn-light btn-lg">
                    <i class="bi bi-search"></i> Browse Projects
                </a>
            }
            @if (User.IsInRole("ModuleLeader") || User.IsInRole("Admin"))
            {
                <a asp-controller="Admin" asp-action="Index"
                       class="btn btn-light btn-lg">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            }
        }
    </div>
</div>

<!-- How It Works Section -->
<div class="container mb-5">
    <h2 class="text-center mb-4 fw-bold">How It Works</h2>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        <i class="bi bi-pencil-square text-primary"
                           style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="card-title fw-bold">1. Student Submits</h5>
                    <p class="card-text text-muted">
                        Students submit their project proposals with a title,
                        abstract, technical stack and research area.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        <i class="bi bi-eye-slash text-warning"
                           style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="card-title fw-bold">2. Blind Review</h5>
                    <p class="card-text text-muted">
                        Supervisors browse proposals anonymously.
                        Student identities are completely hidden during review.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        <i class="bi bi-people text-success"
                           style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="card-title fw-bold">3. Match & Reveal</h5>
                    <p class="card-text text-muted">
                        Once a supervisor confirms interest, both identities
                        are revealed and collaboration can begin.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="container mb-5">
    <h2 class="text-center mb-4 fw-bold">Key Features</h2>
    <div class="row g-3">
        <div class="col-md-6">
            <div class="d-flex align-items-start p-3 border rounded shadow-sm">
                <i class="bi bi-shield-check text-success me-3"
                   style="font-size: 2rem;"></i>
                <div>
                    <h6 class="fw-bold">Bias Free Selection</h6>
                    <p class="text-muted mb-0">
                        Supervisors select projects based on merit,
                        not student identity.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="d-flex align-items-start p-3 border rounded shadow-sm">
                <i class="bi bi-lock text-primary me-3"
                   style="font-size: 2rem;"></i>
                <div>
                    <h6 class="fw-bold">Role Based Access</h6>
                    <p class="text-muted mb-0">
                        Students, Supervisors and Admins each have
                        their own secure dashboard.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="d-flex align-items-start p-3 border rounded shadow-sm">
                <i class="bi bi-graph-up text-warning me-3"
                   style="font-size: 2rem;"></i>
                <div>
                    <h6 class="fw-bold">Real Time Tracking</h6>
                    <p class="text-muted mb-0">
                        Students can track their proposal status
                        from submission to match.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="d-flex align-items-start p-3 border rounded shadow-sm">
                <i class="bi bi-person-check text-danger me-3"
                   style="font-size: 2rem;"></i>
                <div>
                    <h6 class="fw-bold">Identity Reveal</h6>
                    <p class="text-muted mb-0">
                        Once matched, both parties are revealed
                        enabling formal collaboration.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>