@model BlindMatchPAS.Models.Project
@{
    ViewData["Title"] = "Project Details";
}

<div class="container mt-4">
    <div class="mb-4">
        <h2 class="fw-bold">
            <i class="bi bi-file-earmark-text text-primary"></i> Project Details
        </h2>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-dark text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0 fw-bold">@Model.Title</h4>
                <span class="badge rounded-pill
                    @(Model.Status == "Matched" ? "bg-success" :
                                            Model.Status == "Under Review" ? "bg-warning text-dark" :
                                            "bg-secondary")">
                    @if (Model.Status == "Matched")
                    {
                        <i class="bi bi-check-circle"></i>
                    }
                    else if (Model.Status == "Under Review")
                    {
                        <i class="bi bi-hourglass-split"></i>
                    }
                    else
                    {
                        <i class="bi bi-clock"></i>
                    }
                    @Model.Status
                </span>
            </div>
        </div>
        <div class="card-body p-4">
            <dl class="row">
                <dt class="col-sm-3">Research Area</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-primary">@Model.ResearchArea</span>
                </dd>
                <dt class="col-sm-3">Technical Stack</dt>
                <dd class="col-sm-9">@Model.TechnicalStack</dd>
                <dt class="col-sm-3">Abstract</dt>
                <dd class="col-sm-9">@Model.Abstract</dd>
                <dt class="col-sm-3">Submitted On</dt>
                <dt class="col-sm-3">Proposal Document</dt>
                <dd class="col-sm-9">
                    @if (Model.ProposalFile != null)
                    {
                        <a asp-action="DownloadProposal" asp-route-id="@Model.Id"
                               class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-file-earmark-pdf"></i>
                            Download PDF — @Model.ProposalFileName
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">No document uploaded</span>
                    }
                </dd>
                <dd class="col-sm-9">
                    @Model.CreatedAt.ToString("dd MMM yyyy")
                </dd>
            </dl>
        </div>
    </div>

    @if (Model.IsRevealed && Model.SupervisorId != null)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-success text-white py-3">
                <h5 class="mb-0">
                    <i class="bi bi-person-check"></i>
                    Your Supervisor Details
                </h5>
            </div>
            <div class="card-body p-4">
                <dl class="row">
                    <dt class="col-sm-3">Full Name</dt>
                    <dd class="col-sm-9">@ViewBag.SupervisorFullName</dd>

                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@ViewBag.SupervisorEmail</dd>

                    <dt class="col-sm-3">Department</dt>
                    <dd class="col-sm-9">@ViewBag.SupervisorDepartment</dd>
                </dl>
                <div class="alert alert-success mt-3">
                    <i class="bi bi-envelope"></i>
                    Please contact your supervisor via
                    <strong>@ViewBag.SupervisorEmail</strong>
                    to begin your project collaboration.
                </div>
            </div>
        </div>
    }
    else if (Model.Status == "Under Review")
    {
        <div class="alert alert-warning">
            <i class="bi bi-hourglass-split"></i>
            A supervisor has shown interest in your project.
            Waiting for confirmation.
        </div>
    }
    else
    {
        <div class="alert alert-secondary">
            <i class="bi bi-clock"></i>
            Your proposal is currently <strong>@Model.Status</strong>.
            Check back later for updates.
        </div>
    }

    <a asp-action="Index" class="btn btn-secondary mt-2">
        <i class="bi bi-arrow-left"></i> Back to My Projects
    </a>
</div>