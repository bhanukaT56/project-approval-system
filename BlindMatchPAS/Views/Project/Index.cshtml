@model IEnumerable<BlindMatchPAS.Models.Project>
@{
    ViewData["Title"] = "My Projects";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">
                <i class="bi bi-folder2-open text-primary"></i> My Project Proposals
            </h2>
            <p class="text-muted">Manage and track your submitted proposals</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Submit New Proposal
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
            <h4 class="text-muted mt-3">No proposals yet</h4>
            <p class="text-muted">Submit your first project proposal to get started.</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Submit Proposal
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var project in Model)
            {
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header bg-white border-0 pt-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title fw-bold mb-0">@project.Title</h5>
                                <span class="badge rounded-pill
                                    @(project.Status == "Matched" ? "bg-success" :
                                      project.Status == "Under Review" ? "bg-warning text-dark" :
                                      "bg-secondary")">
                                    @if (project.Status == "Matched")
                                    {
                                        <i class="bi bi-check-circle"></i>
                                    }
                                    else if (project.Status == "Under Review")
                                    {
                                        <i class="bi bi-hourglass-split"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-clock"></i>
                                    }
                                    @project.Status
                                </span>
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="text-muted small mb-2">
                                <i class="bi bi-tag"></i> @project.ResearchArea
                            </p>
                            <p class="text-muted small mb-2">
                                <i class="bi bi-stack"></i> @project.TechnicalStack
                            </p>
                            <p class="card-text text-muted">
                                @(project.Abstract.Length > 100
                                    ? project.Abstract.Substring(0, 100) + "..."
                                    : project.Abstract)
                            </p>
                            <p class="text-muted small">
                                <i class="bi bi-calendar"></i>
                                Submitted: @project.CreatedAt.ToString("dd MMM yyyy")
                            </p>
                        </div>
                        <div class="card-footer bg-white border-0 pb-3">
                            <a asp-action="Details" asp-route-id="@project.Id"
                               class="btn btn-sm btn-outline-info me-1">
                                <i class="bi bi-eye"></i> View
                            </a>

                            @if (project.ProposalFile != null)
                            {
                                <a asp-action="DownloadProposal" asp-route-id="@project.Id"
                                       class="btn btn-sm btn-outline-danger me-1">
                                    <i class="bi bi-file-earmark-pdf"></i> PDF
                                </a>
                            }

                            @if (project.Status == "Pending")
                            {
                                <a asp-action="Edit" asp-route-id="@project.Id"
                                   class="btn btn-sm btn-outline-warning me-1">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Withdraw" asp-route-id="@project.Id"
                                   class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Are you sure you want to withdraw?')">
                                    <i class="bi bi-trash"></i> Withdraw
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>